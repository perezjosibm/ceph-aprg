{
  "cluster": {
    "name": "ceph",
    "user": "root",
    "head": "localhost",
    "ceph_conf": "/etc/ceph/ceph.conf",
    "ceph_keyring": "/etc/ceph/ceph.client.admin.keyring",
    "clients": [ "localhost" ],
    "osds": [ "localhost" ],
    "configurations": {
      "sea_1osd_1reactor_1x400GB_rc": {
        "osd_type": "crimson",
        "osd_backend": "seastore",
        "balance_strategy": "default",
        "osd_range": [ 1 ],
        "store_devs": [ "/dev/nvme0n1" ],
        "reactor_core_range": [ 1 ],
        "vstart_cpu_set": [ "0-95" ],
        "pool_type": "rbd",
        "rbd_num_images": 1,
        "rbd_image_size": "400GB"
      },
      "classic_1osd_4x400GB_rc": {
        "osd_type": "classic",
        "osd_backend": "bluestore",
        "osd_range": [ 1 ],
        "store_devs": [ "/dev/nvme0n1"],
        "vstart_cpu_set": [ "0-95" ],
        "pool_type": "rbd",
        "num_rbd_images": 1,
        "rbd_image_size": "400GB"
      }
    }
  },
  "benchmarks": {
    "librbdfio": {
      "cmd_path": "/ceph/build/fio",
      "fio_cpu_range": [ "97-191" ],
      "workloads": {
        "precondition": {
          "fio_catalog": [ "-j -w hockey -r -a -m" ],
          "name": "randrw_70_4k",
          "rw": "randrw",
          "rwmixread": 70,
          "bs": "4k",
          "runtime": 180
        },
        "randwrite": {
          "name": "randrw_70_4k",
          "rw": "randrw",
          "rwmixread": 70,
          "bs": "4k"
        },
        "randread": {
          "name": "randrd_70_4k",
          "rw": "randread",
          "bs": "4k"
        },
        "seqwrite": {
          "name": "randrw_70_64k",
          "rw": "write",
          "bs": "64k"
        },
        "seqread": {
          "name": "read_64k",
          "rw": "read",
          "bs": "64k"
        }
      }
    }
  }
}
